<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp"
    android:layout_marginBottom="8dp"
    android:background="?attr/colorSurface">

    <ImageView
        android:id="@+id/imgCallType"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_arrow_back" /> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_toEndOf="@id/imgCallType"
    android:layout_toStartOf="@id/tvCallDuration">

    <TextView
        android:id="@+id/tvCallNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="01700000000"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurface"/>

    <TextView
        android:id="@+id/tvCallDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10:30 PM | 31 Oct"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="12sp"/>
</LinearLayout>

    <TextView
        android:id="@+id/tvCallDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5m 30s"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="12sp"
        android:layout_marginStart="16dp"/>

</RelativeLayout>