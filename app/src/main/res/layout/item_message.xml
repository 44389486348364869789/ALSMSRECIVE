<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/message_item_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeColor="?attr/colorSurfaceVariant"
    app:strokeWidth="0.5dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_message_bubble"
                app:tint="?attr/colorPrimary" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvSender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            tools:text="NAGAD (SMS)"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintStart_toEndOf="@+id/iconContainer"
            app:layout_constraintTop_toTopOf="@+id/iconContainer"
            app:layout_constraintEnd_toStartOf="@+id/tvTimestamp" />

        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="10:16 PM"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            app:layout_constraintBaseline_toBaselineOf="@+id/tvSender"
            app:layout_constraintEnd_toStartOf="@+id/chk_select"
            app:layout_goneMarginEnd="0dp"/>

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            tools:text="Money Received. Amount: Tk 2200.00. Ref: Payment via API success."
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:autoLink="all"
            android:textColorLink="?attr/colorPrimary"
            app:layout_constraintStart_toStartOf="@+id/tvSender"
            app:layout_constraintEnd_toStartOf="@+id/chk_select"
            app:layout_constraintTop_toBottomOf="@+id/tvSender" />

        <CheckBox
            android:id="@+id/chk_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:visibility="visible"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/viewUnreadIndicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_circle_dot"
            android:visibility="gone"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@+id/tvTimestamp"
            app:layout_constraintEnd_toEndOf="@+id/tvTimestamp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>