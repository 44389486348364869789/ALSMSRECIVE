<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true"
    tools:context=".TrashActivity">

    <RelativeLayout
        android:id="@+id/rlTrashTitleBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:padding="12dp"/>

        <TextView
            android:id="@+id/tvTrashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trash / Deleted Items"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/btnBack"
            android:layout_marginStart="16dp"/>

        <TextView
            android:id="@+id/btnSelectAll"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Select All"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="16sp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="16dp"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

    </RelativeLayout>

    <ProgressBar
        android:id="@+id/progressBarTrash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTrash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/rlTrashTitleBar"
        android:layout_above="@+id/bottom_action_bar"
        android:background="?attr/colorSurfaceVariant"
        tools:listitem="@layout/item_message" />

    <LinearLayout
        android:id="@+id/bottom_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentBottom="true"
        android:visibility="gone"
        tools:visibility="visible"
        android:background="?attr/colorSurface"
        android:padding="8dp">

        <Button
            android:id="@+id/btnRestore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Restore"
            android:backgroundTint="@color/green"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnDeleteForever"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Delete Forever"
            android:backgroundTint="@color/red_error"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</RelativeLayout>